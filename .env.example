# Copia este archivo como .env y rellena los valores. El .env NO se versiona.

# Superusuario inicial de PocketBase (se usa en init-collection.sh y para el panel /_/).
PB_ADMIN_EMAIL=admin@righttoupdates.eu
PB_ADMIN_PASSWORD=cambia-esta-contrasena

# URL base de PocketBase para el script de init.
# En local: http://localhost:8090 — en producción: https://data.righttoupdates.eu
PB_URL=http://localhost:8090
